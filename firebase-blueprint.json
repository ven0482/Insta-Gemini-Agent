{
  "entities": {
    "Profile": {
      "title": "Reference Profile",
      "description": "An Instagram profile handle to monitor for viral trends.",
      "type": "object",
      "properties": {
        "handle": { "type": "string", "description": "Instagram handle (e.g., @cristiano)" },
        "addedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["handle", "addedAt", "userId"]
    },
    "Post": {
      "title": "Generated Post",
      "description": "A post draft generated by the AI agent.",
      "type": "object",
      "properties": {
        "caption": { "type": "string" },
        "topic": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "posted"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["caption", "topic", "status", "createdAt", "userId"]
    },
    "Settings": {
      "title": "User Settings",
      "description": "User configuration, including their own Instagram handle.",
      "type": "object",
      "properties": {
        "myHandle": { "type": "string" },
        "tone": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Research": {
      "title": "Analytic Research",
      "description": "Last successful AI analysis result.",
      "type": "object",
      "properties": {
        "suggestions": { "type": "array", "items": { "$ref": "PostDraft" } },
        "analyzedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["suggestions", "analyzedAt", "userId"]
    },
    "PostDraft": {
      "title": "Post Draft Suggestion",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "caption": { "type": "string" },
        "imagePrompt": { "type": "string" },
        "strategy": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "settings": {
      "schema": "Settings",
      "description": "User-specific application settings."
    },
    "profiles": {
      "schema": "Profile",
      "description": "Collection of Instagram handles to draw inspiration from."
    },
    "posts": {
      "schema": "Post",
      "description": "Collection of generated social media posts."
    },
    "research": {
      "schema": "Research",
      "description": "Storage for last AI analysis suggestions."
    }
  }
}
